{
  "name": "backend",
  "version": "1.0.0",
  "description": "CICJ-SH-COMS Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:deploy": "npx prisma migrate deploy",
    "prisma:seed": "npx prisma db seed",
    "prisma:studio": "npx prisma studio",
    "docker:build": "docker build -t cicj-shcoms-backend .",
    "docker:run": "docker run -p 5000:5000 --env-file .env cicj-shcoms-backend",
    "docker:dev": "docker-compose -f ../docker-compose.dev.yml up",
    "docker:prod": "docker-compose -f ../docker-compose.yml up -d"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "construction",
    "management",
    "api",
    "prisma"
  ],
  "author": "CICJ Team",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "axios": "^1.13.6",
    "basic-ftp": "^5.3.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "prisma": "^6.19.2"
  }
}
