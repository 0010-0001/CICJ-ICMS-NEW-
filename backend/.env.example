# Database Configuration
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Local MySQL/XAMPP example:
DATABASE_URL="mysql://root:@localhost:3306/cicj_shcoms"
# Docker development example (docker-compose.dev.yml):
# DATABASE_URL="mysql://root:root@mysql:3306/cicj_shcoms"

# JWT Authentication
# SECURITY: Change this to a strong random string in production
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="cicj_super_secret_key_2026"

# Server Configuration
PORT=5000
NODE_ENV=production

# CORS Origins (Security: Restrict to specific domains in production)
# Example for single origin: https://yourdomain.com
# Example for multiple: http://localhost:3000,https://yourdomain.com
FRONTEND_URL="*"

# Session Configuration
SESSION_SECRET="your_session_secret_here"

# Security Configuration
# Rate Limiting (requests per 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# HTTPS Enforcement (set to true in production)
ENFORCE_HTTPS=false

# File Upload Limits (in MB)
MAX_FILE_SIZE=10

# Multi-Factor Authentication (MFA) - Email Configuration
# For Gmail: Use App Password (not regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# MFA Settings
MFA_ENABLED=true
OTP_EXPIRY_MINUTES=5

# AES-256 Encryption Configuration
# Generate a secure key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Use different keys for development and production
ENCRYPTION_KEY="your_encryption_key_here_64_hex_characters"
ENCRYPTION_SALT="cicj_shcoms_encryption_salt_change_in_production"

# ==========================================
# CLOUDINARY MEDIA STORAGE (Sprint 3 - Task 1)
# ==========================================
# Create a free account at: https://cloudinary.com/users/register_free
# Your credentials are at: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
# Cloudinary folder structure used:
#   cicj-shcoms/project-files  → progress photos, portfolio images
#   cicj-shcoms/equipment      → equipment photos
# Note: Large blueprint files (>25MB) are stored on LOCAL_FTP, not Cloudinary

# Email Configuration (Optional - for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com

# OAuth Single Sign-On Configuration
# Google Workspace OAuth
# Setup: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
GOOGLE_CALLBACK_URL="http://localhost:5000/oauth/google/callback"
# SMTP_PASSWORD=your_app_password

# reCAPTCHA v2 (Public Inquiry Form)
RECAPTCHA_SECRET_KEY="your_recaptcha_secret_key_here"

# Seed Admin (used by prisma/seed.js)
SEED_ADMIN_NAME="System Admin"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change_me"

# Seed Admin Token (required for POST /admin/seed)
SEED_ADMIN_TOKEN="change_me_token"

# Logging
LOG_LEVEL=info

# PaaS Platform Specific (Render, Heroku, Railway, etc.)
# These are often auto-injected by the platform
# DATABASE_URL (auto-provided by managed MySQL service)
# PORT (auto-provided by platform)
