# Database Configuration
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://cicj_user:cicj_password@mysql:3306/cicj_icms"

# JWT Authentication
# SECURITY: Change this to a strong random string in production
JWT_SECRET="cicj_super_secret_key_2026"

# Server Configuration
PORT=5000
NODE_ENV=production

# CORS Origins (comma-separated for multiple origins)
# Example: http://localhost:3000,https://yourdomain.com
CORS_ORIGIN="*"

# Session Configuration
SESSION_SECRET="your_session_secret_here"

# File Upload Limits (in MB)
MAX_FILE_SIZE=10

# Email Configuration (Optional - for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# Logging
LOG_LEVEL=info

# PaaS Platform Specific (Render, Heroku, Railway, etc.)
# These are often auto-injected by the platform
# DATABASE_URL (auto-provided by managed MySQL service)
# PORT (auto-provided by platform)
